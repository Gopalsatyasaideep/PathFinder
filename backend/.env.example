# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.<zone>.mongodb.net/pathfinder
# IMPORTANT: Special characters in password must be URL-encoded:
#   @ becomes %40
#   : becomes %3A
#   # becomes %23
# Example: password 'gopal@2005' becomes 'gopal%402005'
MONGODB_URL=mongodb+srv://gopal:gopal%402005@cluster0.mgjmdpp.mongodb.net/pathfinder?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret Key - use a strong random string in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# NVIDIA API Key (optional - for premium AI features)
# Get from: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# OpenRouter API Key (optional - for fallback AI features)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# CORS Origins - comma-separated list of allowed frontend URLs
# For local dev: http://localhost:5173
# For production: https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=https://pathfinder-eight-lac.vercel.app
