# PathFinder AI - Environment Configuration

# ==============================================
# API KEYS CONFIGURATION
# ==============================================

# NVIDIA API Configuration (Premium AI features)
# Get your key from: https://build.nvidia.com/explore/discover
# Example: NVIDIA_API_KEY=nvapi-abc123...
NVIDIA_API_KEY=

# OpenRouter API Configuration (Free tier fallback)  
# Get your key from: https://openrouter.ai/keys
# Example: OPENROUTER_API_KEY=sk-or-v1-abc123...
OPENROUTER_API_KEY=

# ==============================================
# JOB SEARCH API KEYS (For Real Job Fetching)
# ==============================================

# Adzuna API (Free tier: 250 calls/month)
# Get your keys from: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# RapidAPI Key (For JSearch - Indeed, LinkedIn, Glassdoor aggregate)
# Get your key from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 2500 requests/month
RAPIDAPI_KEY=

# Reed UK Jobs API (Free: 1000 calls/month)
# Get your key from: https://www.reed.co.uk/developers
REED_API_KEY=

# USAJobs API (Free - US Government jobs)
# Get your key from: https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=PathFinderApp/1.0

# ==============================================
# AI SERVICE PREFERENCES
# ==============================================

# Whether to prefer NVIDIA API over OpenRouter (true/false)
PREFER_NVIDIA_API=true

# Default AI model settings
AI_TEMPERATURE=0.6
AI_MAX_TOKENS=4096

# ==============================================
# APPLICATION SETTINGS  
# ==============================================

# Backend server settings
BACKEND_HOST=localhost
BACKEND_PORT=8000

# Frontend settings
FRONTEND_HOST=localhost  
FRONTEND_PORT=5173

# ==============================================
# DEVELOPMENT SETTINGS
# ==============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable debug mode (true/false)
DEBUG_MODE=false

# ==============================================
# INSTRUCTIONS
# ==============================================
# 1. Copy this file to .env in the backend/ directory
# 2. Fill in your API keys
# 3. Restart the backend server
# 4. The application will automatically detect and use available APIs